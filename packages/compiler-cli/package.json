{
  "name": "@angular/compiler-cli",
  "version": "0.0.0-PLACEHOLDER",
  "description": "Angular - the compiler CLI for Node.js",
  "typings": "index.d.ts",
  "bin": {
    "ngcc": "./bundles/ngcc_bin.js",
    "ngc": "./bundles/ngc_bin.js",
    "ng-xi18n": "./bundles/xi18n_bin.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "default": "./bundles/compiler_cli.js"
    },
    "./package.json": {
      "default": "./package.json"
    },
    "./ngcc": {
      "default": "./bundles/ngcc_index.js"
    },
    "./linker": {
      "default": "./bundles/linker.js"
    },
    "./linker/babel": {
      "default": "./bundles/linker_babel.js"
    },
    "./private/bazel": {
      "default": "./bundles/private_bazel.js"
    },
    "./private/localize": {
      "default": "./bundles/private_localize.js"
    },
    "./private/migrations": {
      "default": "./bundles/private_migrations.js"
    }
  },
  "dependencies": {
    "chokidar": "^3.0.0",
    "semver": "^7.0.0",
    "yargs": "^17.0.0"
  },
  "peerDependencies": {
    "typescript": ">=4.2.3 <4.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/angular/angular.git",
    "directory": "packages/compiler-cli"
  },
  "keywords": [
    "angular",
    "compiler"
  ],
  "license": "MIT",
  "engines": {
    "node": "^12.14.1 || >=14.0.0"
  },
  "bugs": {
    "url": "https://github.com/angular/angular/issues"
  },
  "homepage": "https://github.com/angular/angular/tree/master/packages/compiler-cli",
  "ng-update": {
    "packageGroup": "NG_UPDATE_PACKAGE_GROUP"
  }
}
